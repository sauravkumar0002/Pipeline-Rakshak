# ============================================================
# AI Corrosion Detection Platform — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# Never commit your actual .env to version control.

# ── Database ────────────────────────────────────────────────
# SQLite (default, local dev):
# DATABASE_URL=sqlite:///./corrosion_detection.db
# PostgreSQL (Supabase production — URL-encode special chars, e.g. @ → %40):
# DATABASE_URL=postgresql://USER:PASSWORD%40SUFFIX@HOST:5432/DBNAME?sslmode=require
DATABASE_URL=sqlite:///./corrosion_detection.db

# ── Auth ─────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_use_a_long_random_secret_32chars_minimum
# Optional — JWT token lifetime in minutes (default 480 = 8h)
# ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Directories ─────────────────────────────────────────────
MODEL_DIRECTORY=backend/models/onnx
UPLOAD_DIRECTORY=uploads
REPORT_DIRECTORY=reports

# ── Default ONNX model to load on startup ───────────────────
DEFAULT_MODEL=mobilenetv2_standard.onnx

# ── CORS allowed origins ─────────────────────────────────────
# Comma-separated JSON list. Default covers local dev.
# ALLOWED_ORIGINS=["https://your-frontend.netlify.app"]

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Frontend (Vite) ──────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000

# ── Storage Backend ──────────────────────────────────────────
# "local"    — write files to local disk (default, dev-friendly).
# "supabase" — upload to Supabase Storage buckets; set URL + key below.
STORAGE_BACKEND=local

# Supabase project URL (e.g. https://<ref>.supabase.co)
SUPABASE_URL=

# Supabase service-role key — KEEP SECRET, never commit to git.
# Rotate this key at: Supabase dashboard → Settings → API → Rotate key
SUPABASE_SERVICE_KEY=

